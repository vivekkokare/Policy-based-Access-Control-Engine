  "engine_policies": [
    {
      "uid": "doctor_policy_1",
      "scenario": "Doctor reads patient records for treatment when consent is active",
      "role": "doctor",
      "target": "patient_records",
      "action": "read",
      "effect": "permit",
      "constraints": [
        {
          "leftOperand": "purpose",
          "operator": "eq",
          "rightOperand": "treatment"
        },
        {
          "leftOperand": "consent_status",
          "operator": "eq",
          "rightOperand": "active"
        }
      ],
      "duties": [
        {
          "action": "log_access"
        }
      ]
    },
    {
      "uid": "doctor_policy_2",
      "scenario": "Doctor denied access if patient consent revoked",
      "role": "doctor",
      "target": "patient_records",
      "action": "read",
      "effect": "deny",
      "constraints": [
        {
          "leftOperand": "consent_status",
          "operator": "eq",
          "rightOperand": "revoked"
        }
      ]
    },
    {
